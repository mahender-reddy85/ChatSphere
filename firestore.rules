rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Rooms collection with participant-based access - Updated for invite code lookup
    match /rooms/{roomId} {
      // Allow authenticated users to read rooms for invite code lookup (metadata only)
      allow read: if request.auth != null;
      
      // Only authenticated users can create rooms with max 2 participants
      allow create: if request.auth != null && 
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() <= 2;
      
      // Strict update rules - only allow adding participants, max 2 total
      allow update: if request.auth != null && 
        // Must be existing participant (can add new users)
        request.auth.uid in resource.data.participants &&
        // Cannot remove participants, only add new ones
        request.resource.data.participants.size() >= resource.data.participants.size() &&
        // Cannot exceed 2 participants
        request.resource.data.participants.size() <= 2 &&
        // Only allow updating specific safe fields
        request.resource.data.keys().hasAll(['participants', 'updatedAt', 'isFull']) &&
        request.resource.data.keys().size() <= 3 &&
        // Preserve critical fields
        request.resource.data.inviteCode == resource.data.inviteCode &&
        request.resource.data.chatMode == resource.data.chatMode &&
        request.resource.data.createdAt == resource.data.createdAt;
      
      // Messages subcollection
      match /messages/{messageId} {
        // Only participants can read messages
        allow read: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.participants;
        
        // Only participants can create messages
        allow create: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.participants &&
          request.auth.uid == request.resource.data.senderId;
        
        // No one can update or delete messages (immutable)
        allow update, delete: if false;
      }
    }
  }
}
