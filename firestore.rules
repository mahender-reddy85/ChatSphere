rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Rooms collection with participant-based access
    match /rooms/{roomId} {
      // Allow authenticated users to read rooms for invite code lookup
      allow read: if request.auth != null && 
        (request.auth.uid in resource.data.participants || resource.data.allowJoin == true);
      
      // Only authenticated users can create rooms
      allow create: if request.auth != null && 
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() <= 2;
      
      // Only participants can update room data
      allow update: if request.auth != null && 
        request.auth.uid in resource.data.participants;
      
      // Messages subcollection
      match /messages/{messageId} {
        // Only participants can read messages
        allow read: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.participants;
        
        // Only participants can create messages
        allow create: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.participants &&
          request.auth.uid == request.resource.data.senderId;
        
        // No one can update or delete messages (immutable)
        allow update, delete: if false;
      }
    }
  }
}
