rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // USERS
    match /users/{userId} {
      allow read, write: if request.auth != null 
        && request.auth.uid == userId;
    }

    // ROOMS
    match /rooms/{roomId} {

      // READ: allow only if participant OR room allows joining
      allow read: if request.auth != null;
      
      // LIST: allow authenticated users to query rooms they're in or public rooms  
      allow list: if request.auth != null;

      // CREATE: allow authenticated users to create rooms
      allow create: if request.auth != null &&
        request.resource.data.participants.size() == 1 &&
        request.resource.data.participants[0] == request.auth.uid &&
        request.resource.data.inviteCode is string &&
        request.resource.data.inviteCode.size() > 0 &&
        request.resource.data.allowJoin == true &&
        request.resource.data.createdAt == request.resource.data.createdAt;

      // UPDATE: allow existing participants to update OR new users to join
      allow update: if request.auth != null &&
        (
          // EXISTING PARTICIPANT can update some fields
          request.auth.uid in resource.data.participants
          
          ||
          
          // NEW USER JOINING
          (
            resource.data.allowJoin == true &&
            !(request.auth.uid in resource.data.participants) &&
            request.auth.uid in request.resource.data.participants &&
            request.resource.data.participants.size() <= 2
          )
        )

        // PROTECT CRITICAL FIELDS
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.resource.data.createdAt == resource.data.createdAt;

      // DELETE: allow participants to delete room
      allow delete: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      // MESSAGES
      match /messages/{messageId} {

        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.participants;

        allow create: if request.auth != null &&
          request.auth.uid == request.resource.data.senderId &&
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.participants;

        allow update, delete: if false;
      }
    }
  }
}