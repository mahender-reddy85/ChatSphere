rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // USERS
    match /users/{userId} {
      allow read, write: if request.auth != null 
        && request.auth.uid == userId;
    }

    // ROOMS
    match /rooms/{roomId} {

      // READ: allow only if participant OR joining via invite code query
      allow read: if request.auth != null &&
        (
          request.auth.uid in resource.data.participants
          || resource.data.allowJoin == true
        );

      // LIST: allow querying by inviteCode for joining
      allow list: if request.auth != null &&
        request.query.limit <= 10 &&
        request.query.where.0.field == 'inviteCode' &&
        request.query.where.0.op == '==';

      // CREATE
      allow create: if request.auth != null &&
        request.resource.data.participants.size() == 1 &&
        request.resource.data.participants[0] == request.auth.uid;

      // UPDATE (JOIN + SAFE UPDATE)
      allow update: if request.auth != null &&
        (
          // EXISTING PARTICIPANT
          (
            request.auth.uid in resource.data.participants &&
            request.resource.data.participants.size() <= 2 &&
            resource.data.participants.toSet().subsetOf(request.resource.data.participants.toSet())
          )

          ||

          // NEW USER JOIN
          (
            resource.data.allowJoin == true &&
            request.resource.data.participants.size() <= 2 &&
            request.auth.uid not in resource.data.participants &&
            request.auth.uid in request.resource.data.participants &&
            resource.data.participants.toSet().subsetOf(request.resource.data.participants.toSet())
          )
        )

        // PROTECT FIELDS
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.resource.data.createdAt == resource.data.createdAt

        // AUTO LOCK ROOM
        && request.resource.data.allowJoin == (request.resource.data.participants.size() < 2);
      

      // MESSAGES
      match /messages/{messageId} {

        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.participants;

        allow create: if request.auth != null &&
          request.auth.uid == request.resource.data.senderId &&
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.participants;

        allow update, delete: if false;
      }
    }
  }
}